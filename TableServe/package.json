{
  "name": "tableserve",
  "version": "1.0.0",
  "description": "Offline table service POS for single-computer restaurant use.",
  "main": "backend/server.js",
  "scripts": {
    "dev": "concurrently \"npm run server\" \"npm run frontend\"",
    "server": "nodemon backend/server.js",
    "frontend": "cmd /c \"cd frontend && npm run dev\"",
    "start": "node backend/server.js"
  },
  "keywords": [
    "pos",
    "restaurant",
    "offline",
    "sqlite"
  ],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "dependencies": {
    "better-sqlite3": "^12.8.0",
    "cors": "^2.8.6",
    "express": "^5.2.1"
  },
  "devDependencies": {
    "concurrently": "^9.2.1",
    "nodemon": "^3.1.14"
  }
}
